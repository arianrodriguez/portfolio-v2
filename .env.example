# Copia este archivo como .env.local (ya está en .gitignore) para desarrollo
# local con `vercel dev`. En producción, define estas variables en
# Vercel → Project → Settings → Environment Variables.

# Requerida — API key de Resend (https://resend.com → API Keys)
RESEND_API_KEY=

# Opcional — a dónde te llegan las solicitudes
CONTACT_TO_EMAIL=

# Opcional — remitente. Funciona tal cual para pruebas; tras verificar tu
# dominio en Resend, cámbialo a algo como "Arian <contacto@tudominio.com>"
CONTACT_FROM_EMAIL=Portafolio <onboarding@resend.dev>

# --- Anti-bot: Cloudflare Turnstile (https://dash.cloudflare.com → Turnstile) ---
# Site key (PÚBLICA, va al front). Debe llamarse con prefijo VITE_ para que
# Vite la exponga al cliente. Si la dejas vacía, el widget no se muestra.
VITE_TURNSTILE_SITE_KEY=

# Secret key (PRIVADA, solo servidor). Si la defines, el token se verifica.
TURNSTILE_SECRET_KEY=

# Opcional — hosts/orígenes extra permitidos además de tu dominio Vercel
# (ej. tu dominio propio). Separa con comas. *.vercel.app ya está permitido.
ALLOWED_ORIGINS=
