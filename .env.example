# Copia este archivo como .env.local (ya está en .gitignore) para desarrollo
# local con `vercel dev`. En producción, define estas variables en
# Vercel → Project → Settings → Environment Variables.

# Requerida — API key de Resend (https://resend.com → API Keys)
RESEND_API_KEY=

# Opcional — a dónde te llegan las solicitudes
CONTACT_TO_EMAIL=

# Opcional — remitente. Funciona tal cual para pruebas; tras verificar tu
# dominio en Resend, cámbialo a algo como "Arian <contacto@tudominio.com>"
CONTACT_FROM_EMAIL=Portafolio <onboarding@resend.dev>
